{
    "version": 2,
    "builds": [
        {
            "src": "backend/api.py",
            "use": "@vercel/python"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/api.py"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}